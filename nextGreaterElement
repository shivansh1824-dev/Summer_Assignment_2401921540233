#include <bits/stdc++.h>
using namespace std;

vector<int> nextGreaterElement(vector<int> &nums1, vector<int> &nums2)
{
    stack<int> s;
    unordered_map<int, int> mp;
    int idx = nums2.size() - 1;
    mp[nums2[idx]] = -1;
    s.push(nums2[idx]);
    for (int i = idx - 1; i >= 0; i--)
    {
        while (!s.empty() && s.top() <= nums2[i])
        {
            s.pop();
        }

        if (s.empty())
            mp[nums2[i]] = -1;
        else
            mp[nums2[i]] = s.top();

        s.push(nums2[i]);
    }

    vector<int> ans;

    for (int j : nums1)
    {
        ans.push_back(mp[j]);
    }

    return ans;
}
